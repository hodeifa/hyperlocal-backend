# ==============================================================================
# HYPERLOCAL BACKEND - ENVIRONMENT VARIABLES
# ==============================================================================
# Cara pakai: Copy file ini menjadi `.env` dan isi dengan nilai asli/lokal Anda.
# cp .env.example .env
# ==============================================================================

# ==========================================
# 1. INFRASTRUCTURE (Docker Compose & DB)
# ==========================================
# Digunakan oleh docker-compose.yml dan Go microservices untuk koneksi DB
POSTGRES_USER=hyperlocal
POSTGRES_PASSWORD=hyperlocal_secret
POSTGRES_DB=hyperlocal
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable
# ==========================================
# Database Connection Pool Settings (pkg/database)
# ==========================================
DB_MAX_CONNS=20
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

MINIO_ROOT_USER=hyperlocal
MINIO_ROOT_PASSWORD=hyperlocal_secret123
MINIO_ENDPOINT=localhost:9000
MINIO_USE_SSL=false
MINIO_REGION=ap-southeast-1
MINIO_BUCKET_CHAT=chat-attachments

# ==========================================
# 2. APP & GATEWAY CONFIG
# ==========================================
APP_ENV=development
API_GATEWAY_PORT=8080
API_GATEWAY_HOST=0.0.0.0

# JWT Configuration (Access 24h, Refresh 90d)
JWT_SECRET=change-this-to-a-very-long-random-string-in-production
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=2160h

# Database Encryption Key (Wajib untuk pgcrypto / enkripsi rekening bank)
# Generate nilai asli via terminal: openssl rand -hex 32
ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_STRING_FOR_PGCRYPTO

# ==========================================
# 3. BUSINESS CONSTANTS (Do not hardcode!)
# ==========================================
# Nilai default dalam Rupiah (IDR)
TOTAL_FARE=6000
MITRA_SERVICE_FEE=5000
PLATFORM_FEE_PER_ORDER=1000
MINIMUM_WALLET_BALANCE=20000
WALLET_WARNING_THRESHOLD=25000

# Top-up Virtual Account Limits
MIN_TOPUP_AMOUNT=20000
MAX_TOPUP_AMOUNT=1000000
VA_EXPIRY_HOURS=24

# ==========================================
# 4. EXTERNAL INTEGRATIONS
# ==========================================
# [FIXv2.4] Flip Business (Virtual Account Provider)
# Gunakan sandbox credentials untuk development
FLIP_API_KEY=flip_sandbox_api_key
FLIP_SECRET_KEY=flip_sandbox_secret_key_for_hmac_sha256
FLIP_BASE_URL=https://bigflip.id/api
FLIP_WEBHOOK_PATH=/internal/flip/callback

# Firebase Cloud Messaging (FCM)
# Bisa berupa Server Key (Legacy) atau path ke Service Account JSON
FCM_SERVER_KEY=your-fcm-server-key-or-path-to-json

# SMS / OTP Provider (Misal: Twilio, Fonnte,atau Gateway lokal)
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret
SMS_SENDER_ID=Hyperlocal

# ==========================================
# 5. MAPS & GEOSPATIAL (Self-Hosted OSM)
# ==========================================
# URL internal Docker (jika service berjalan di dalam container)
# Gunakan localhost jika Go binary dijalankan langsung di host machine
OSRM_BASE_URL=http://localhost:5000
NOMINATIM_BASE_URL=http://localhost:7070

# ==========================================
# 6. MICROSERVICE PORTS (Internal gRPC/HTTP)
# ==========================================
CUSTOMER_SERVICE_PORT=8081
DRIVER_SERVICE_PORT=8082
ORDER_SERVICE_PORT=8083
LOCATION_SERVICE_PORT=8084
CHAT_SERVICE_PORT=8085
CHAT_WORKER_PORT=8086
MAP_SERVICE_PORT=8087

# Logging
LOG_LEVEL=info